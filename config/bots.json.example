{
  "defaults": {
    "mattermost": {
      "url": "http://127.0.0.1:8065"
    },
    "llm": {
      "provider": "openai",
      "baseUrl": "https://api.openai.com/v1",
      "stream": true
    }
  },
  "bots": [
    {
      "name": "support-ja",
      "llm": {
        "model": "gpt-5.4-mini"
      }
    },
    {
      "name": "review-en",
      "llm": {
        "model": "gpt-5.4",
        "reasoningEffort": "high",
        "verbosity": "medium"
      }
    }
  ]
}
